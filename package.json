{
  "name": "face-marker-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "visual": "playwright test",
    "visual:ui": "playwright test --ui",
    "visual:headed": "playwright test --headed",
    "visual:update": "playwright test --update-snapshots",
    "visual:report": "playwright show-report",
    "visual:chromium": "playwright test --project=chromium",
    "visual:firefox": "playwright test --project=firefox",
    "visual:webkit": "playwright test --project=webkit",
    "visual:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "visual:debug": "playwright test --debug",
    "e2e": "playwright test e2e/",
    "e2e:ui": "playwright test e2e/ --ui",
    "e2e:headed": "playwright test e2e/ --headed",
    "e2e:debug": "playwright test e2e/ --debug",
    "e2e:report": "playwright show-report",
    "perf": "vite performance.html --open",
    "perf:quick": "vite performance.html --open",
    "perf:report": "vite performance.html --open"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mediapipe/face_detection": "^0.4.1646425229",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@tensorflow-models/face-detection": "^1.0.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-webgpu": "^4.22.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/ui": "^4.0.10",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "playwright": "^1.56.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.10"
  }
}
